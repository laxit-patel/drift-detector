#!/usr/bin/env bash
# Self-bootstrapping launcher for the Drift Detector read-only MCP server.
# Provisions an isolated venv with the MCP SDK (once), then runs the stdio server pointed at a
# scan's state dir. Wire it into an MCP host (Claude Code/.mcp.json, Cursor, Claude Desktop) with:
#     <plugin>/bin/drift-mcp --state /path/to/folder/.drift-detector
set -euo pipefail

PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-}"
if [ -z "$PLUGIN_ROOT" ]; then
  PLUGIN_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
fi
VENV="$PLUGIN_ROOT/.venv-mcp"
MARKER="$VENV/.drift-mcp-ok"
REQ="$PLUGIN_ROOT/requirements-mcp.txt"
PYVER="3.12"

if [ ! -f "$MARKER" ]; then
  echo "drift-mcp: first-run setup — installing the MCP SDK (one-time)…" >&2
  if command -v uv >/dev/null 2>&1; then
    uv venv --python "$PYVER" "$VENV" 1>&2
    VIRTUAL_ENV="$VENV" uv pip install -q -r "$REQ" 1>&2
  elif command -v python3 >/dev/null 2>&1 && python3 -c 'import ensurepip, venv' 2>/dev/null; then
    python3 -m venv "$VENV"
    "$VENV/bin/python" -m pip install -q -r "$REQ" 1>&2
  else
    echo "drift-mcp: need 'uv' or python3>=3.11 with venv." >&2
    exit 3
  fi
  touch "$MARKER"
fi

exec env PYTHONPATH="$PLUGIN_ROOT${PYTHONPATH:+:$PYTHONPATH}" \
  "$VENV/bin/python" -m agent.mcp_server "$@"
